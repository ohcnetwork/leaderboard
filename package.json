{
  "name": "leaderboard",
  "version": "0.0.0",
  "private": true,
  "description": "",
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^20.19.39",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "data:setup": "cd packages/plugin-runner && tsx src/index.ts setup",
    "data:import": "cd packages/plugin-runner && tsx src/index.ts import",
    "data:scrape": "cd packages/plugin-runner && tsx src/index.ts scrape",
    "data:aggregate": "cd packages/plugin-runner && tsx src/index.ts aggregate",
    "data:evaluate": "cd packages/plugin-runner && tsx src/index.ts evaluate",
    "data:export": "cd packages/plugin-runner && tsx src/index.ts export",
    "db:seed": "pnpm --filter @ohcnetwork/leaderboard-api seed",
    "build:packages": "pnpm --filter @ohcnetwork/leaderboard-api build && pnpm --filter @leaderboard/plugin-runner build && pnpm --filter @leaderboard/plugin-dummy build && pnpm --filter create-leaderboard-plugin build && pnpm --filter create-leaderboard-data-repo build && pnpm --filter mcp-server build",
    "build:data": "cd packages/plugin-runner && tsx src/index.ts",
    "build:web": "pnpm --filter leaderboard-web build",
    "build": "pnpm build:packages && pnpm build:data && pnpm build:web",
    "clean": "pnpm -r clean",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r test:watch",
    "test:coverage": "pnpm -r test:coverage",
    "setup:dev": "tsx scripts/setup-dev.ts",
    "clean:dev": "rm -rf data/",
    "reset:dev": "pnpm clean:dev && pnpm setup:dev",
    "dev": "pnpm --filter leaderboard-web dev",
    "mcp": "pnpm --filter @leaderboard/mcp-server dev",
    "create-data-repo": "tsx packages/create-data-repo/src/index.ts",
    "generate:schema": "tsx scripts/generate-config-schema.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "changeset": "changeset",
    "version": "changeset version",
    "publish": "pnpm build:packages && changeset publish"
  },
  "keywords": [],
  "packageManager": "pnpm@10.33.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ohcnetwork/leaderboard.git"
  },
  "author": "Open Healthcare Network",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ohcnetwork/leaderboard/issues"
  },
  "homepage": "https://github.com/ohcnetwork/leaderboard#readme",
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": "prettier --write",
    "*.{json,yaml,yml,md,mdx,css,html}": "prettier --write"
  },
  "dependencies": {
    "create-leaderboard-data-repo": "link:packages/create-data-repo",
    "create-leaderboard-plugin": "link:packages/create-plugin"
  }
}
