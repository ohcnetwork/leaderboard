{
  "name": "@leaderboard/mcp-server",
  "version": "0.2.0",
  "description": "Model Context Protocol (MCP) server for querying leaderboard data",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "private": false,
  "bin": {
    "leaderboard-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/index.ts --transport http",
    "dev:worker": "wrangler dev",
    "deploy:worker": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "leaderboard",
    "database",
    "query",
    "api"
  ],
  "author": "Open Healthcare Network",
  "license": "MIT",
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@ohcnetwork/leaderboard-api": "workspace:*",
    "agents": "^0.10.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250410.0",
    "@types/node": "^20.19.39",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.3",
    "wrangler": "^4.14.0"
  }
}
